#!/usr/bin/env php
<?php

// #!/usr/bin/env php → c'est le "shebang".
// Il dit au système : "ce fichier doit être exécuté par PHP".
// Grâce à ça, sur Linux/Mac, on peux taper "./bin/sf-doctor" directement
// au lieu de "php bin/sf-doctor".
// Sur Windows, tape "php bin/sf-doctor".

// --- Étape 1 : Charger l'autoloader ---
// C'est toujours la première chose à faire dans un script PHP.
// Sans ça, PHP ne sait pas où trouver SfDoctor\Model\Issue, etc.
require __DIR__ . '/../vendor/autoload.php';

use SfDoctor\Analyzer\Security\AccessControlAnalyzer;
use SfDoctor\Analyzer\Security\FirewallAnalyzer;
use SfDoctor\Command\AuditCommand;
use SfDoctor\Config\YamlConfigReader;
use SfDoctor\Report\ConsoleReporter;
use Symfony\Component\Console\Application;

// --- Étape 2 : Déterminer le chemin du projet à auditer ---
// Par défaut, on audite le répertoire courant (là où la commande est lancée).
// L'utilisateur lance "php bin/sf-doctor" depuis la racine de son projet Symfony.
$projectPath = getcwd();

// --- Étape 3 : Câblage manuel ---

// 3a. Le lecteur de config a besoin du chemin du projet
$configReader = new YamlConfigReader($projectPath);

// 3b. Les analyzers ont besoin du lecteur de config
$analyzers = [
    new FirewallAnalyzer($configReader),
    new AccessControlAnalyzer($configReader),
];

// 3c. On ne peut pas créer le ConsoleReporter ici car on n'a pas encore
// l'OutputInterface. La commande le créera elle-même dans execute().
// Pour l'instant, on passe un tableau vide de reporters

// --- Étape 4 : Créer l'application Console ---
// Application est la coquille qui gère les commandes.
// C'est le "bin/console" de Symfony, en miniature.
$application = new Application('SF Doctor', '0.1.0');

// --- Étape 5 : Enregistrer la commande ---
$application->add(new AuditCommand($analyzers, [], $projectPath));

// --- Étape 6 : Lancer l'application ---
// run() lit les arguments de la ligne de commande ($_SERVER['argv']),
// trouve la bonne commande, et l'exécute.
$application->setDefaultCommand('sf-doctor:audit', true);
$application->run();