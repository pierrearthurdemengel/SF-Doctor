{
    "name": "pierre-arthur/sf-doctor",
    "description": "Automated audit tool for Symfony projects",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Pierre -Arthur DEMENGEL",
            "email": "pierrearthur.demengel@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/console": "^6.4 || ^7.0",
        "symfony/yaml": "^6.4 || ^7.0",
        "symfony/finder": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "SfDoctor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SfDoctor\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}