{
    "name": "pierre-arthur/sf-doctor",
    "description": "Automated audit tool for Symfony projects",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Pierre -Arthur DEMENGEL",
            "email": "pierrearthur.demengel@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/console": "^6.4 || ^7.0",
        "symfony/yaml": "^6.4 || ^7.0",
        "symfony/finder": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/config": "^6.4 || ^7.0",
        "dompdf/dompdf": "^3.1",
        "symfony/serializer": "^7.4",
        "symfony/property-access": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "symfony/framework-bundle": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "PierreArthur\\SfDoctor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PierreArthur\\SfDoctor\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
